groups:
- name: targets
  rules:
  - alert: monitor_service_down
    expr: up == 0
    for: 300s
    labels:
      severity: critical
    annotations:
      summary: "Monitor service non-operational"
      description: "Service {{ $labels.instance }} is down."

- name: host
  rules:
  - alert: high_cpu_load
    expr: node_load1 / count by (instance, job) (node_cpu_seconds_total{mode="idle"}) > 1.5
    for: 300s
    labels:
      severity: warning
    annotations:
      summary: "High CPU load on {{ $labels.instance }}"
      description: '1m load on {{ $labels.instance }} (job {{ $labels.job }}) is {{ printf "%.2f" $value }} per core.'

  - alert: high_memory_load
    expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100 > 85
    for: 300s
    labels:
      severity: warning
    annotations:
      summary: "High memory usage on {{ $labels.instance }}"
      description: 'Memory usage on {{ $labels.instance }} (job {{ $labels.job }}) is {{ printf "%.1f" $value }}%.'

  - alert: high_storage_load
    expr: (1 - (node_filesystem_avail_bytes{fstype!~"tmpfs|overlay|squashfs|aufs|ramfs|devtmpfs|nsfs|fuse.*"} / node_filesystem_size_bytes{fstype!~"tmpfs|overlay|squashfs|aufs|ramfs|devtmpfs|nsfs|fuse.*"})) * 100 > 85
    for: 300s
    labels:
      severity: warning
    annotations:
      summary: "High storage usage on {{ $labels.instance }} ({{ $labels.mountpoint }})"
      description: 'Filesystem {{ $labels.mountpoint }} on {{ $labels.instance }} (job {{ $labels.job }}) is {{ printf "%.1f" $value }}% full.'

- name: containers
  rules:
  - alert: traefik_down
    expr: count(container_memory_usage_bytes{name="traefik"}) by (instance) < 1 or absent(container_memory_usage_bytes{name="traefik"})
    for: 300s
    labels:
      severity: critical
    annotations:
      summary: "traefik down on {{ $labels.instance }}"
      description: "traefik container is down for more than 5 minutes on {{ $labels.instance }}."

  - alert: traefik_high_cpu
    expr: sum(rate(container_cpu_usage_seconds_total{name="traefik"}[1m])) by (instance) / on(instance) count(node_cpu_seconds_total{mode="system"}) by (instance) * 100 > 10
    for: 300s
    labels:
      severity: warning
    annotations:
      summary: "traefik high CPU usage on {{ $labels.instance }}"
      description: "traefik CPU usage is {{ humanize $value}}% on {{ $labels.instance }}."

  - alert: traefik_high_memory
    expr: sum(container_memory_usage_bytes{name="traefik"}) by (instance) > 2147483648
    for: 300s
    labels:
      severity: warning
    annotations:
      summary: "traefik high memory usage on {{ $labels.instance }}"
      description: "traefik memory consumption is at {{ humanize $value}} on {{ $labels.instance }}."
